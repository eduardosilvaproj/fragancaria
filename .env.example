# =====================================================
# FRAGRANCIARIA - Variáveis de Ambiente
# =====================================================

# SUPABASE (Frontend - Client)
# Encontre essas chaves em: https://supabase.com/dashboard → seu projeto → Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-anon-aqui

# SUPABASE (Backend - Server)
# IMPORTANTE: Essas variáveis são necessárias para salvar pedidos no Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# MERCADO PAGO
# Encontre em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxx

# Z-API (WhatsApp)
# Painel: https://z-api.io → sua instância → configurações
# Nunca prefixar com VITE_: essas chaves ficam somente no servidor.
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
# Opcional: use se a proteção Client Token estiver habilitada na Z-API.
ZAPI_CLIENT_TOKEN=
# Crie um segredo longo. Configure o callback na Z-API como:
# https://SEU-DOMINIO/api/public/whatsapp-webhook?secret=SEU_SEGREDO
ZAPI_WEBHOOK_SECRET=

# SHOPIFY (opcional - para integração futura)
# VITE_SHOPIFY_STORE_DOMAIN=sua-loja.myshopify.com
# VITE_SHOPIFY_STOREFRONT_TOKEN=seu-token-aqui

# ANALYTICS (opcional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_META_PIXEL_ID=1234567890

# MERCADO PAGO - Webhook (opcional, recomendado em produção)
# Crie em: https://www.mercadopago.com.br/developers/panel/notifications/webhooks
# Cole o mesmo valor na configuração de Webhooks do painel.
# Se deixar vazio, o webhook aceita qualquer request (dev).
MP_WEBHOOK_SECRET=

# URL publica (usada como fallback da notification_url do MP)
PUBLIC_URL=https://www.fragranciaria.com

# SERPER.DEV - busca de imagens de produto no editor do admin
# Crie a chave (2500 buscas gratis) em: https://serper.dev
# SECRET server-only: NUNCA prefixar com VITE_ (vazaria no bundle do browser).
SERPER_API_KEY=

# MERCADO LIVRE - app para ler anuncios da PROPRIA conta (opcional)
# Painel: https://developers.mercadolivre.com.br
# Obs: a API so entrega anuncios da propria conta; itens de terceiro dao 403.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
