{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "nodeVersion": "20.x",
  "installCommand": "npm install",
  "functions": {
    "dist/server/server.js": {
      "runtime": "@vercel/node@3.0.0"
    },
    "api/*.ts": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    { "source": "/static/(.*)", "destination": "/dist/client/$1" },
    { "source": "/(.*)", "destination": "/dist/server/server.js" }
  ]
}
